# Required for verified live research
OPENAI_API_KEY=
SEARCH_API_KEY=
SEARCH_PROVIDER=tavily

# Optional but recommended for full-page evidence extraction
FIRECRAWL_API_KEY=

# Vector database / RAG
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional licensed contact enrichment; use only compliant sources
HUNTER_API_KEY=
PEOPLE_DATA_LABS_API_KEY=
CLEARBIT_API_KEY=

# App auth, if needed
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Local development persistence
LOCAL_DATA_DIR=.data

# Webex OAuth Integration — authenticates the connected Webex user for
# meeting/transcript access on their behalf (Signal Agent Webex pilot).
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
WEBEX_REDIRECT_URI=http://localhost:3010/api/webex/oauth/callback
WEBEX_SCOPES=meeting:transcripts_read meeting:schedules_read spark:people_read spark:rooms_read spark:messages_write

# Webex Bot access token — separate identity used only to SEND outbound
# alert messages (never used for reading meetings/transcripts).
WEBEX_BOT_ACCESS_TOKEN=

# Peachtree pilot two-lane routing recipients (read by server code only —
# never hard-coded in components or routing conditionals).
WEBEX_SALES_RECIPIENT_EMAIL=
WEBEX_TECHNICAL_RECIPIENT_EMAIL=

# Autonomous webhook mode. Leave WEBEX_PUBLIC_BASE_URL empty during manual
# testing; Webex cannot deliver webhooks to localhost. WEBEX_WEBHOOK_SECRET
# is optional and, if set, is used to validate the X-Spark-Signature header
# on incoming webhook requests.
WEBEX_PUBLIC_BASE_URL=
WEBEX_AUTOPILOT_ENABLED=false
WEBEX_WEBHOOK_SECRET=
