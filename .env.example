# ─── Circuit AI provider (the only active generative-AI provider) ──────
# Circuit is an enterprise AI gateway reached with an OAuth2
# client-credentials token. The client id, client secret, and App Key are
# secrets; the access token is short-lived runtime state and is NEVER an
# env var. The confirmed inference contract REQUIRES the App Key
# (CIRCUIT_APP_KEY, sent as a JSON string in the request body `user`
# field). Endpoints and model are configuration-driven and never
# hard-coded in source. Circuit is an OPTIONAL enhancement layer; when
# unconfigured/unavailable the deterministic engine remains fully
# authoritative. Fill real values in .env.local (never commit them).
AI_PROVIDER=circuit
CIRCUIT_CLIENT_ID=
CIRCUIT_CLIENT_SECRET=
# Token contract CONFIRMED + live-verified: HTTP Basic auth
# (base64 client_id:client_secret) with body grant_type=client_credentials.
# Cisco Okta token endpoint:
CIRCUIT_TOKEN_URL=https://id.cisco.com/oauth2/default/v1/token
# Inference contract CONFIRMED + live-verified: OpenAI/Azure-compatible
# chat/completions. The model is a deployment in the URL path — use a
# {model} placeholder and it is substituted with CIRCUIT_MODEL. Auth is the
# `api-key: <access-token>` header (not Bearer).
CIRCUIT_INFERENCE_URL=https://chat-ai.cisco.com/openai/deployments/{model}/chat/completions
CIRCUIT_MODEL=gemini-3.1-flash-lite
# App Key REQUIRED by the inference contract (sent as a JSON string in the
# request body `user` field). Secret — set in .env.local, never commit.
CIRCUIT_APP_KEY=
CIRCUIT_SCOPE=
CIRCUIT_AUDIENCE=
CIRCUIT_TIMEOUT_MS=45000
CIRCUIT_MAX_RETRIES=2
# Used only when the token response omits expires_in and has no JWT exp.
CIRCUIT_TOKEN_FALLBACK_TTL_SECONDS=3000
CIRCUIT_TOKEN_REFRESH_SKEW_SECONDS=60
CIRCUIT_PROMPT_VERSION=signal-to-action-circuit-v1
CIRCUIT_SCHEMA_VERSION=1.0
# The wire contract in src/lib/circuit/contract.ts has been confirmed
# against the Circuit notebook. Until this is set to true, NO live token
# or inference request is sent (the client returns
# CIRCUIT_CONTRACT_UNCONFIRMED) so the provisional/assumed request shapes
# can never run silently. Set to true only after confirming contract.ts.
CIRCUIT_CONTRACT_CONFIRMED=false
CIRCUIT_CONTRACT_VERSION=

# Server-only. When true, the Signal Agent run treats Circuit as REQUIRED:
# it promotes each validated stage's output into the canonical fields and,
# if a required stage does not run, surfaces the exact stage + safe error
# code in result.circuit_run.required_failure (analysis_mode
# deterministic_fallback) instead of quietly labeling the result
# deterministic. Promotion of successful stages happens regardless; this
# only controls required-failure surfacing. Never expose in browser code.
CIRCUIT_REQUIRED=false

SEARCH_API_KEY=
SEARCH_PROVIDER=tavily
# Dedicated SerpAPI connector (@/lib/connectors/serpapi) used by the
# Signal-to-Solution qualification pipeline — set SEARCH_PROVIDER=serpapi
# above to use it (reuses the same SEARCH_API_KEY; no second key needed).
SERPAPI_ENGINE=google
SERPAPI_LANGUAGE=en
SERPAPI_COUNTRY=us
SERPAPI_SAFE=active
SERPAPI_MAX_QUERIES_PER_RUN=8
SERPAPI_MAX_RESULTS_PER_QUERY=10
SERPAPI_DEFAULT_RESULT_LIMIT=5
SERPAPI_CACHE_TTL_SECONDS=86400
SERPAPI_REQUEST_TIMEOUT_MS=15000
SERPAPI_MAX_RETRIES=2
SERPAPI_SECOND_PAGE_ENABLED=false

# Optional but recommended for full-page evidence extraction
FIRECRAWL_API_KEY=

# Vector database / RAG
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional licensed contact enrichment; use only compliant sources
HUNTER_API_KEY=
PEOPLE_DATA_LABS_API_KEY=
CLEARBIT_API_KEY=

# App auth, if needed
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Local development persistence
LOCAL_DATA_DIR=.data

# Webex OAuth Integration — authenticates the connected Webex user for
# identity, outbound messaging, and (optionally) meeting/transcript
# access on their behalf (Signal Agent Webex pilot).
#
# "Connect Webex" only ever requests the required core scopes
# (spark:people_read, spark:messages_write, meeting:schedules_read).
# meeting:transcripts_read is optional and requested only by the
# separate "Enable transcript access" action — a Webex Integration that
# has not had meeting:transcripts_read selected/saved will still connect
# successfully. See @/lib/webex/scopePolicy.
WEBEX_CLIENT_ID=
WEBEX_CLIENT_SECRET=
WEBEX_REDIRECT_URI=http://localhost:3010/api/webex/oauth/callback
WEBEX_SCOPES=spark:people_read spark:messages_write meeting:schedules_read meeting:transcripts_read

# Webex Bot access token — OPTIONAL fallback sender only. Webex direct
# messages default to the connected user's own OAuth token (requires the
# spark:messages_write scope above); a bot is never required for delivery.
WEBEX_BOT_ACCESS_TOKEN=

# Auto-send after analysis (Demo/Paste/Upload/manually-selected Webex
# transcripts) — leave unset to use the computed default (enabled once
# both Webex delivery and Outlook Mail.Send are connected), or set
# explicitly to force it on/off regardless of connection state.
SIGNAL_AGENT_AUTO_SEND_ENABLED=

# Autonomous webhook mode (Webex transcript autopilot). Leave
# WEBEX_PUBLIC_BASE_URL empty during manual testing; Webex cannot deliver
# webhooks to localhost. WEBEX_WEBHOOK_SECRET is optional and, if set, is
# used to validate the X-Spark-Signature header on incoming webhook
# requests. This is separate from auto-send above.
WEBEX_PUBLIC_BASE_URL=
WEBEX_AUTOPILOT_ENABLED=false
WEBEX_WEBHOOK_SECRET=

# Outlook / Microsoft Graph OAuth — real email delivery via POST
# /me/sendMail (delegated Mail.Send). Register a web-app in Microsoft
# Entra with this exact redirect URI, delegated User.Read + Mail.Send
# permissions, and request openid/profile/offline_access so the
# authorization-code flow returns a refresh token.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=organizations
MICROSOFT_REDIRECT_URI=http://localhost:3010/api/outlook/oauth/callback
MICROSOFT_SCOPES=openid profile offline_access User.Read Mail.Send

# Peachtree pilot two-lane routing recipients (Bella/Jack) are stored
# directly in signal-agent-poc/config/peachtree_pilot_routing.json —
# no environment variables are required or read for this pilot.

# Public analysis-link base URL — REQUIRED for the "Open full analysis"
# link to ever be sent to Bella/Jack. Must be a real, publicly reachable
# HTTPS origin (the deployed app's own domain) — never localhost,
# 127.0.0.1, or a private-LAN address; those are always rejected and the
# outbound message falls back to a plain-text "Analysis reference: Run
# <id>" instead of a dead/localhost hyperlink. Leave empty during local
# development. See @/lib/signal-agent/analysisLink.
APP_PUBLIC_BASE_URL=
SIGNAL_SHARE_LINK_TTL_HOURS=168
# HMAC secret used to sign the read-only share token embedded in the
# link (?token=...). Required for a durable deployment — without it, a
# random per-process secret is used, which invalidates all previously
# issued links on every restart.
SIGNAL_SHARE_LINK_SECRET=
