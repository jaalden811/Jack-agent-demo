# Signal-to-Action Agent POC — environment variables
#
# Copy this file to `.env` and fill in values locally. Never commit `.env`.
# `.env` is already listed in `.gitignore`.
#
# OpenAI is OPTIONAL. The agent works fully offline with deterministic
# keyword/phrase matching when this is not set (see skills/detect_painpoint.py).
OPENAI_API_KEY=

# Optional: override the OpenAI model used for pain-point synthesis.
OPENAI_MODEL=gpt-4o-mini

# --- Future adapters (not called in this POC; stubs only) ---
# Reserved variable names for a future Webex CLI/API adapter behind skills/notify.py.
# No Webex calls are made in this POC.
WEBEX_BOT_TOKEN=
WEBEX_NOTIFY_ROOM_ID=

# Reserved variable names for a future Outlook CLI/Graph adapter behind skills/notify.py.
# No Outlook calls are made in this POC.
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
