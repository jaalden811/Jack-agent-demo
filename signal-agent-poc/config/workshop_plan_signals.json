  ],
  "timing_cues": [
    "planning cycle", "planning boundary", "next quarter", "late next quarter",
    "before the next", "next planning", "this quarter", "practical boundary"
  ],
  "procurement_not_required_cues": [
    "procurement does not need to join", "procurement not required", "procurement does not need",
    "no need for procurement", "procurement does not", "procurement is not"
  ]
}
