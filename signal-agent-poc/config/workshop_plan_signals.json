    "scenario", "use case", "one should be", "one should involve", "one could be",
    "recreate the", "the identity case", "the operational case", "for the identity",
    "for the operational", "for the security", "degraded", "suspicious identity",
    "regional visibility", "reliability scenario", "investigation scenario", "the bar is"
  ],
  "data_source_terms": [
    "cloud metrics", "application traces", "app traces", "authentication logs", "auth logs",
    "network experience", "network telemetry", "network activity", "infrastructure metrics",
    "infrastructure health", "servicenow change", "change records", "change events", "change event",
    "device posture", "recent access", "vulnerability context", "endpoint data", "identity data",
    "application logs", "security signals", "telemetry", "traces"
  ],
  "participant_request_cues": [
    "who else should participate", "who should participate", "who else should", "should join",
    "should participate", "someone from", "should be in the room", "not only operations",
    "should attend", "who should attend", "bring in", "include"
  ],
  "participant_role_terms": [
    "architecture", "service management", "enterprise risk", "security architecture",
    "application owner", "operations", "network team", "cloud team", "finance",
    "vendor management", "procurement", "reliability", "infrastructure", "security team"
