{
  "metadata": {
    "purpose": "Objective-aware research plan. Maps seller objectives to public-research query intents (templates with placeholders — never account-specific strings). Only PUBLIC facts that could change the recipient's action/relevance. Never plans searches for private data (quota, deal value, renewal date, internal budget, procurement state).",
    "version": "1.0.0",
    "placeholders": ["{account}", "{industry}", "{geography}", "{product_motion}", "{transcript_theme}"]
  },
  "forbidden_signal_intents": ["quota", "opportunity_value", "renewal_date", "internal_budget", "opportunity_stage", "procurement_state", "customer_commitment"],
  "rules": [
    {
      "objective_id": "grow_strategic_accounts",
      "applicable_taxonomy_categories": [],
      "required_account_resolution": "probable",
      "query_intents": [
        { "intent_id": "company_scale", "purpose": "Establish account scale/strategic weight.", "template": "{account} revenue employees global footprint", "required_inputs": ["account"], "optional_inputs": ["industry"], "accepted_signal_types": ["company_scale", "revenue", "employee_count", "site_footprint"], "max_queries": 1 },
        { "intent_id": "strategic_priorities", "purpose": "Public strategic objectives that a large deal could support.", "template": "{account} strategic priorities investor day transformation", "required_inputs": ["account"], "optional_inputs": [], "accepted_signal_types": ["public_strategic_objectives", "investor_priorities", "capital_investment"], "max_queries": 1 }
      ],
      "message_fields_affected": ["why_now", "goal_alignment", "account_importance"],
      "relevance_dimensions_affected": ["account_ownership", "opportunity_size_alignment", "goal_alignment"],
      "active": true
    },
    {
      "objective_id": "prioritize_large_enterprise",
      "applicable_taxonomy_categories": [],
      "required_account_resolution": "probable",
      "query_intents": [
        { "intent_id": "company_scale", "purpose": "Confirm enterprise scale.", "template": "{account} annual revenue number of employees", "required_inputs": ["account"], "optional_inputs": ["industry"], "accepted_signal_types": ["company_scale", "revenue", "employee_count"], "max_queries": 1 }
      ],
      "message_fields_affected": ["goal_impact", "account_importance"],
      "relevance_dimensions_affected": ["opportunity_size_alignment"],
      "active": true
    },
    {
      "objective_id": "expand_security_portfolio",
      "applicable_taxonomy_categories": ["soc_detection_response", "siem_compliance", "identity_zero_trust", "ai_security", "ot_security"],
      "required_account_resolution": "probable",
      "query_intents": [
        { "intent_id": "public_security_initiatives", "purpose": "Public security modernization / regulatory drivers.", "template": "{account} security modernization {transcript_theme} compliance", "required_inputs": ["account"], "optional_inputs": ["industry", "transcript_theme"], "accepted_signal_types": ["public_security_initiatives", "regulatory_exposure", "public_incidents"], "max_queries": 1 }
      ],
      "message_fields_affected": ["why_now", "risk", "action_priority"],
      "relevance_dimensions_affected": ["goal_alignment", "timing_alignment"],
      "active": true
    },
    {
      "objective_id": "expand_observability",
      "applicable_taxonomy_categories": ["cloud_native_observability", "service_health_aiops", "digital_experience"],
      "required_account_resolution": "probable",
      "query_intents": [
        { "intent_id": "public_cloud_initiatives", "purpose": "Public cloud/observability transformation drivers.", "template": "{account} cloud transformation observability reliability {transcript_theme}", "required_inputs": ["account"], "optional_inputs": ["transcript_theme"], "accepted_signal_types": ["public_cloud_initiatives", "public_transformation_programs", "public_ai_initiatives"], "max_queries": 1 }
      ],
      "message_fields_affected": ["why_now", "strategic_alignment"],
      "relevance_dimensions_affected": ["goal_alignment"],
      "active": true
    },
    {
      "objective_id": "prioritize_ai_initiatives",
      "applicable_taxonomy_categories": ["ai_infrastructure", "ai_security"],
      "required_account_resolution": "confirmed",
      "query_intents": [
        { "intent_id": "public_ai_initiatives", "purpose": "Public AI programs/investment.", "template": "{account} artificial intelligence initiative investment", "required_inputs": ["account"], "optional_inputs": [], "accepted_signal_types": ["public_ai_initiatives", "capital_investment"], "max_queries": 1 }
      ],
      "message_fields_affected": ["why_now", "goal_alignment"],
      "relevance_dimensions_affected": ["goal_alignment"],
      "active": true
    }
  ]
}
